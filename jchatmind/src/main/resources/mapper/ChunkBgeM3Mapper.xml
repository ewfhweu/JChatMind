<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kama.jchatmind.mapper.ChunkBgeM3Mapper">

    <resultMap id="BaseResultMap" type="com.kama.jchatmind.model.entity.ChunkBgeM3">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="parentId" column="parent_id" jdbcType="VARCHAR"/>
        <result property="kbId" column="kb_id" jdbcType="VARCHAR"/>
        <result property="docId" column="doc_id" jdbcType="VARCHAR"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="type" column="type" jdbcType="INTEGER"/>
        <result property="headingPath" column="heading_path" jdbcType="VARCHAR"/>
        <result property="headingLevel" column="heading_level" jdbcType="INTEGER"/>
        <result property="metadata" column="metadata" jdbcType="VARCHAR"/>
        <result property="embedding" column="embedding" jdbcType="OTHER"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,parent_id,kb_id,doc_id,
        content,type,heading_path,heading_level,
        metadata,embedding,created_at,updated_at
    </sql>

    <insert id="insert" parameterType="com.kama.jchatmind.model.entity.ChunkBgeM3"
            keyColumn="id" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO chunk_bge_m3
        (
            parent_id,
            kb_id,
            doc_id,
            content,
            type,
            heading_path,
            heading_level,
            metadata,
            embedding,
            created_at,
            updated_at
        )
        VALUES
            (
                CAST(#{parentId} AS uuid),
                CAST(#{kbId} AS uuid),
                CAST(#{docId} AS uuid),
                #{content},
                #{type},
                #{headingPath},
                #{headingLevel},
                #{metadata},
                #{embedding}::vector,
                #{createdAt},
                #{updatedAt}
            )
    </insert>

    <insert id="batchInsert" parameterType="java.util.List"
            keyColumn="id" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO chunk_bge_m3
        (
            parent_id,
            kb_id,
            doc_id,
            content,
            type,
            heading_path,
            heading_level,
            metadata,
            embedding,
            created_at,
            updated_at
        )
        VALUES
        <foreach collection="list" item="item" separator=",">
            (
                CAST(#{item.parentId} AS uuid),
                CAST(#{item.kbId} AS uuid),
                CAST(#{item.docId} AS uuid),
                #{item.content},
                #{item.type},
                #{item.headingPath},
                #{item.headingLevel},
                #{item.metadata},
                #{item.embedding}::vector,
                #{item.createdAt},
                #{item.updatedAt}
            )
        </foreach>
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM chunk_bge_m3
        WHERE id = CAST(#{id} AS uuid)
    </select>

    <select id="selectByDocId" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM chunk_bge_m3
        WHERE doc_id = CAST(#{docId} AS uuid)
        ORDER BY heading_level, created_at
    </select>

    <select id="selectByParentId" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM chunk_bge_m3
        WHERE parent_id = CAST(#{parentId} AS uuid)
        ORDER BY created_at
    </select>

    <delete id="deleteById">
        DELETE FROM chunk_bge_m3 WHERE id = CAST(#{id} AS uuid)
    </delete>

    <delete id="deleteByDocId">
        DELETE FROM chunk_bge_m3 WHERE doc_id = CAST(#{docId} AS uuid)
    </delete>

    <update id="updateById" parameterType="com.kama.jchatmind.model.entity.ChunkBgeM3">
        UPDATE chunk_bge_m3
        <set>
            <if test="parentId != null">
                parent_id = CAST(#{parentId} AS uuid),
            </if>
            <if test="kbId != null">
                kb_id = CAST(#{kbId} AS uuid),
            </if>
            <if test="docId != null">
                doc_id = CAST(#{docId} AS uuid),
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="type != null">
                type = #{type},
            </if>
            <if test="headingPath != null">
                heading_path = #{headingPath},
            </if>
            <if test="headingLevel != null">
                heading_level = #{headingLevel},
            </if>
            <if test="metadata != null">
                metadata = #{metadata},
            </if>
            <if test="embedding != null">
                embedding = #{embedding}::vector,
            </if>
            updated_at = NOW()
        </set>
        WHERE id = CAST(#{id} AS uuid)
    </update>

    <select id="similaritySearch" resultMap="BaseResultMap">
        <![CDATA[
        SELECT
            <include refid="Base_Column_List"/>
        FROM chunk_bge_m3
        WHERE kb_id = CAST(#{kbId} AS uuid)
        ORDER BY embedding <-> #{vectorLiteral}::vector
        LIMIT #{limit}
        ]]>
    </select>
</mapper>
